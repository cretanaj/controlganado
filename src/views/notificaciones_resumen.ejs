<%- include('partials/_header') %>
<%- include('partials/_menu') %>
<div class="main">
    <%- include('partials/_menuheader') %>
    <main class="content">
        <div class="container-fluid">
            <div class="header">
                <h1 class="header-title">
                    Notificaciones
                </h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                    </ol>
                </nav>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Notificaciones generadas</h5>
                            <h6 class="card-subtitle text-muted">Resultado de la vista _vw_notificaciones.</h6>
                        </div>
                        <div class="card-body">
                            <table id="datatables-reponsive" class="table table-striped" style="width:100%" data-skip-datatable="true">
                                <thead>
                                    <tr>
                                        <th>N°</th>
                                        <th>Codigo Notificacion</th>
                                        <th>Nombre Notificacion</th>
                                        <th>Tipo</th>
                                        <th>Animal</th>
                                        <th>Nombre Animal</th>
                                        <th>Dias Animal</th>
                                        <th>Tipo Regla</th>
                                        <th>Criterio</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (data && data.length > 0) { %>
                                        <% for (var i = 0; i < data.length; i++) { %>
                                            <tr>
                                                <td><%= i + 1 %></td>
                                                <td><%= data[i].codigoNotificacion %></td>
                                                <td><%= data[i].nombreNotificacion %></td>
                                                <td><%= data[i].codigoTipoNotificacion || '' %></td>
                                                <td><%= data[i].codigoAnimal %></td>
                                                <td><%= data[i].nombreAnimal %></td>
                                                <td><%= data[i].diasAnimal %></td>
                                                <td><%= data[i].tipoRegla %></td>
                                                <td><%= data[i].criterio || '' %></td>
                                            </tr>
                                        <% } %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="9" class="text-center text-muted">No hay notificaciones generadas.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
<%- include('partials/_footer') %>
