<%- include('partials/_header') %>
<%- include('partials/_menu') %>
<div class="main">
    <%- include('partials/_menuheader') %>
    <main class="content">
        <div class="container-fluid">
            <div class="header">
                <h1 class="header-title">Inventario</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                    </ol>
                </nav>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Inventario</h5>
                            <h6 class="card-subtitle text-muted">Administracion de inventario por producto, finca y usuario.</h6>
                        </div>
                        <div class="card-body">
                            <% const canManageInventarios = can('inventarios', 'editar') || can('inventarios', 'eliminar'); %>
                            <table id="datatables-reponsive" class="table table-striped" style="width:100%">
                                <thead>
                                    <tr>
                                        <th>N°</th>
                                        <th>Producto</th>
                                        <th>Finca</th>
                                        <th>Usuario</th>
                                        <th>Cantidad</th>
                                        <th>Fecha</th>
                                        <% if (canManageInventarios) { %>
                                        <th>Acciones</th>
                                        <% } %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (data) { %>
                                        <% for (var i = 0; i < data.length; i++) { %>
                                            <tr>
                                                <td><%= i + 1 %></td>
                                                <td><%= data[i].codigoProducto %> - <%= data[i].nombreProducto %></td>
                                                <td><%= data[i].codigoFinca %> - <%= data[i].nombreFinca %></td>
                                                <td><%= data[i].codigoUsuario %> - <%= data[i].nombreUsuario %> - <%= data[i].nombreCompleto %></td>
                                                <td><%= data[i].cantidad %></td>
                                                <td><%= data[i].fechaFormateada %></td>
                                                <% if (canManageInventarios) { %>
                                                <td class="table-action">
                                                    <% if (can('inventarios', 'editar')) { %>
                                                    <a href="/inventarios/updateInventario/<%= data[i].idProducto %>/<%= data[i].idFinca %>/<%= data[i].idUsuario %>/<%= data[i].fechaIso %>"><i class="align-middle fas fa-fw fa-pen"></i></a>
                                                    <% } %>
                                                    <% if (can('inventarios', 'eliminar')) { %>
                                                    <a href="/inventarios/deleteInventario/<%= data[i].idProducto %>/<%= data[i].idFinca %>/<%= data[i].idUsuario %>/<%= data[i].fechaIso %>"><i class="align-middle fas fa-fw fa-trash"></i></a>
                                                    <% } %>
                                                </td>
                                                <% } %>
                                            </tr>
                                        <% } %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <% if (can('inventarios', 'crear')) { %>
            <div class="row">
                <div class="col-12 col-xl-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Agregar un registro</h5>
                            <h6 class="card-subtitle text-muted">Seleccione producto, finca, usuario y fecha.</h6>
                        </div>
                        <div class="card-body">
                            <form action="/inventarios/addInventario" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Producto</label>
                                    <select name="idProducto" class="form-control" required>
                                        <option value="">-- Seleccionar producto --</option>
                                        <% if (dataProductos) { %>
                                            <% for (var i = 0; i < dataProductos.length; i++) { %>
                                                <option value="<%= dataProductos[i].idProducto %>"><%= dataProductos[i].codigo %> - <%= dataProductos[i].nombre %></option>
                                            <% } %>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Finca</label>
                                    <select name="idFinca" class="form-control" required>
                                        <option value="">-- Seleccionar finca --</option>
                                        <% if (dataFincas) { %>
                                            <% for (var i = 0; i < dataFincas.length; i++) { %>
                                                <option value="<%= dataFincas[i].idFinca %>"><%= dataFincas[i].codigo %> - <%= dataFincas[i].nombre %></option>
                                            <% } %>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Usuario</label>
                                    <select name="idUsuario" class="form-control" required>
                                        <option value="">-- Seleccionar usuario --</option>
                                        <% if (dataUsuarios) { %>
                                            <% for (var i = 0; i < dataUsuarios.length; i++) { %>
                                                <option value="<%= dataUsuarios[i].idUsuario %>"><%= dataUsuarios[i].codigo %> - <%= dataUsuarios[i].nombreUsuario %> - <%= dataUsuarios[i].nombreCompleto %></option>
                                            <% } %>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Cantidad</label>
                                    <input type="number" step="0.01" class="form-control" name="cantidad" placeholder="Cantidad">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Fecha</label>
                                    <input type="date" class="form-control" name="fecha" required>
                                </div>
                                <button type="submit" class="btn btn-primary">Salvar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>

        </div>
    </main>
<%- include('partials/_footer') %>
