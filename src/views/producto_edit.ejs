<%- include('partials/_header') %>
<%- include('partials/_menu') %>

<div class="main">
    <%- include('partials/_menuheader') %>
    <main class="content">
        <div class="container-fluid">
            <div class="header">
                <h1 class="header-title">
                    Productos
                </h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                    </ol>
                </nav>
            </div>

            <div class="row">
                <div class="col-12 col-xl-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Actualizar un registro</h5>
                            <h6 class="card-subtitle text-muted">Ingrese la informacion solicitada a continuacion.</h6>
                        </div>
                        <div class="card-body">
                            <form action="/productos/updateProducto/<%= data.idProducto %>" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Codigo</label>
                                    <input type="text" class="form-control" name="codigo" placeholder="Codigo" value="<%= data.codigo %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Nombre</label>
                                    <input type="text" class="form-control" name="nombre" placeholder="Nombre" value="<%= data.nombre %>" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Descripcion</label>
                                    <textarea class="form-control" name="descripcion" rows="3" maxlength="500" placeholder="Descripcion"><%= data.descripcion %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Fecha Compra</label>
                                    <input type="date" class="form-control" name="fechaCompra" value="<%= data.fechaCompraFmt || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Fecha Fabricacion</label>
                                    <input type="date" class="form-control" name="fechaFabricacion" value="<%= data.fechaFabricacionFmt || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Fecha Caducidad</label>
                                    <input type="date" class="form-control" name="fechaCaducidad" value="<%= data.fechaCaducidadFmt || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Cantidad</label>
                                    <input type="number" step="0.01" class="form-control" name="cantidad" placeholder="Cantidad" value="<%= data.cantidad %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Lote</label>
                                    <input type="text" class="form-control" name="lote" placeholder="Lote" value="<%= data.lote %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Proveedor</label>
                                    <select name="idProveedor" class="form-control" id="idProveedor">
                                        <option value="">-- Seleccionar proveedor --</option>
                                        <% if (dataProveedores) { %>
                                            <% for (var i = 0; i < dataProveedores.length; i++) { %>
                                                <option value="<%= dataProveedores[i].idProveedor %>" <%= Number(data.idProveedor) === Number(dataProveedores[i].idProveedor) ? 'selected' : '' %>><%= dataProveedores[i].nombre %></option>
                                            <% } %>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Numero Factura</label>
                                    <input type="text" class="form-control" name="numeroFactura" placeholder="Numero Factura" value="<%= data.numeroFactura %>">
                                </div>
                                <button type="submit" class="btn btn-primary">Salvar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        </div>
</div>

<%- include('partials/_footer') %>
