<%- include('partials/_header') %>
<%- include('partials/_menu') %>

<div class="main">
    <%- include('partials/_menuheader') %>
    <main class="content">
        <div class="container-fluid">
            <div class="header">
                <h1 class="header-title">
                    Proveedores
                </h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                    </ol>
                </nav>
            </div>

            <div class="row">
                <div class="col-12 col-xl-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">Actualizar un registro</h5>
                            <h6 class="card-subtitle text-muted">Ingrese la informacion solicitada a continuacion.</h6>
                        </div>
                        <div class="card-body">
                            <form action="/proveedores/updateProveedor/<%= data.idProveedor %>" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Codigo</label>
                                    <input type="text" class="form-control" name="codigo" placeholder="Codigo" value="<%= data.codigo %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Nombre</label>
                                    <input type="text" class="form-control" name="nombre" placeholder="Nombre" value="<%= data.nombre %>" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Telefono 1</label>
                                    <input type="text" class="form-control" name="telefono1" placeholder="Telefono 1" value="<%= data.telefono1 %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Contacto 1</label>
                                    <input type="text" class="form-control" name="contacto1" placeholder="Contacto 1" value="<%= data.contacto1 %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Telefono 2</label>
                                    <input type="text" class="form-control" name="telefono2" placeholder="Telefono 2" value="<%= data.telefono2 %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Contacto 2</label>
                                    <input type="text" class="form-control" name="contacto2" placeholder="Contacto 2" value="<%= data.contacto2 %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Descripcion</label>
                                    <textarea class="form-control" name="descripcion" rows="3" maxlength="500" placeholder="Descripcion"><%= data.descripcion %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Correo</label>
                                    <input type="email" class="form-control" name="correo" placeholder="Correo" value="<%= data.correo %>">
                                </div>
                                <button type="submit" class="btn btn-primary">Salvar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        </div>
</div>

<%- include('partials/_footer') %>
